# VoiceJournal Backend Environment Variables Example
# Copy this file to .env and fill in the values.

# Security
# MUST CHANGE in production! Generate a secure random string (e.g., `openssl rand -hex 32`)
SECRET_KEY=change_this_to_a_secure_random_string_in_production
# Used for encrypting audio files at rest. Must be 32 URL-safe base64-encoded bytes.
ENCRYPTION_KEY=t8vE9V5bY6hB8t4rT2xP9uN5hF1yA7vC3wL9zS0kX6M=
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
# Default: sqlite:///./voicejournal.db
# For PostgreSQL: postgresql://user:password@localhost/voicejournal
DATABASE_URL=sqlite:///./voicejournal.db

# Celery / Redis
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AWS S3 (Optional - mock local used by default)
S3_BUCKET_NAME=voicejournal-audio-dev
AWS_ACCESS_KEY_ID=mock
AWS_SECRET_ACCESS_KEY=mock
AWS_REGION=us-east-1

# AI Models
# Set to 'cuda' if running on a GPU, otherwise 'cpu'
MODEL_DEVICE=cpu
